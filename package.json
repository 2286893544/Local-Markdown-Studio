{
  "name": "local-markdown-studio",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first desktop Markdown reader and editor.",
  "main": "electron/main.cjs",
  "scripts": {
    "app": "electron .",
    "package:mac": "electron-packager . \"Local Markdown Studio\" --platform=darwin --arch=$(node -p \"process.arch\") --out=dist --overwrite --extend-info=electron/mac-info.plist --ignore='^/docs' --ignore='^/test' --ignore='^/dist' --ignore='^/.codegraph' && node scripts/prune-mac-package.cjs",
    "package:win": "electron-packager . \"Local Markdown Studio\" --platform=win32 --arch=x64 --out=dist --overwrite --ignore='^/docs' --ignore='^/test' --ignore='^/dist' --ignore='^/.codegraph' && node scripts/prune-win-package.cjs",
    "dmg:mac": "npm run package:mac && node scripts/dmg-mac-package.cjs",
    "zip:mac": "npm run package:mac && node scripts/zip-mac-package.cjs",
    "zip:win": "npm run package:win && node scripts/zip-win-package.cjs",
    "test": "node test/markdown.test.mjs && node test/project.test.mjs && node test/app-source.test.mjs && node test/electron-source.test.mjs",
    "check": "node --check src/app.js && node --check src/markdown.mjs && node --check src/project.mjs && node --check electron/main.cjs && node --check electron/preload.cjs"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^31.7.7"
  }
}
